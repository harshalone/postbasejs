{
  "name": "postbasejs",
  "version": "0.3.5",
  "description": "The official JavaScript client for Postbase — self-hosted backend as a service",
  "keywords": [
    "postbase",
    "database",
    "auth",
    "storage",
    "backend",
    "self-hosted",
    "postgresql",
    "baas"
  ],
  "homepage": "https://www.getpostbase.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/harshalone/postbasejs.git"
  },
  "bugs": {
    "url": "https://github.com/harshalone/postbasejs/issues"
  },
  "license": "MIT",
  "author": "Postbase",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.ts",
      "import": "./dist/ssr/index.mjs",
      "require": "./dist/ssr/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
